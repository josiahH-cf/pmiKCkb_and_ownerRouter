# Synthetic, non-secret "golden" production env used only by the cutover dry-run rehearsal and
# its unit tests. Every value is fake (note the unmistakable `sample-kb-fixture-*` naming) and
# must never be treated as a real credential. It exists to prove the production cutover gates
# compute a clean verdict; it is not a real environment. See scripts/cutover-dry-run.mjs.
GCP_PROJECT_ID=sample-kb-fixture-prod
FIREBASE_PROJECT_ID=sample-kb-fixture-prod
NEXT_PUBLIC_FIREBASE_PROJECT_ID=sample-kb-fixture-prod
NEXT_PUBLIC_FIREBASE_API_KEY=fixture-not-a-real-firebase-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=sample-kb-fixture-prod.firebaseapp.com
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:fixturewebappidnotreal
APP_BASE_URL=https://kb.sample-kb-fixture.example
ALLOWED_HD=pmikcmetro.com
ASK_DEMO_MODE=false
LOCAL_DEMO_AUTH=false
GEMINI_MODEL_ANSWER=gemini-2.5-flash
KB_APPROVAL_NOTIFICATIONS_ENABLED=false
KB_APPROVAL_SENDER=
KB_APPROVAL_RECIPIENTS=
CLOUD_RUN_SERVICE_ACCOUNT=kb-runtime@sample-kb-fixture-prod.iam.gserviceaccount.com
SPACE_DRIVE_FOLDER_IDS={"lease-renewals":"fixture-drive-folder-lease-renewals"}
SPACE_VERTEX_DATA_STORE_IDS={"lease-renewals":"kb-lease-renewals-fixture-txt"}
# The maintenance photo Drive folder is a write target, kept out of the KB-source maps above (so the
# cross-link stays clean). Prod forces the Drive image store, so the preflight requires this.
MAINTENANCE_PHOTO_DRIVE_FOLDER_ID=fixture-drive-folder-maintenance-photos
# Dev↔prod parity (S12): the non-secret live-connection anchors. The RentVine base URL is the real
# pmikcmetro tenant host shape (public, not a secret); the api key/secret are delivered via Secret
# Manager (--set-secrets), never in this env. The DWD subject is a pmikcmetro.com user (identity rule).
RENTVINE_API_BASE_URL=https://pmikcmetro.rentvine.com/api/manager
RENEWAL_SHEET_ID=sample-kb-fixture-renewal-sheet-id
SHEETS_IMPERSONATE_SA=kb-sheets-reader@sample-kb-fixture-prod.iam.gserviceaccount.com
SHEETS_DWD_SUBJECT=kb-reader@pmikcmetro.com
GMAIL_DWD_SA=workflow-mail@sample-kb-fixture-prod.iam.gserviceaccount.com
GMAIL_PUBSUB_PUSH_SERVICE_ACCOUNT=gmail-pubsub-push@sample-kb-fixture-prod.iam.gserviceaccount.com
GMAIL_PUBSUB_TOPIC=projects/sample-kb-fixture-prod/topics/gmail-workflow-events
GMAIL_PUBSUB_AUDIENCE=https://kb.sample-kb-fixture.example/api/gmail-hub/pubsub
