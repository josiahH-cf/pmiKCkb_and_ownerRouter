rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return request.auth.token.role;
    }

    function editorOrBetter() {
      return role() in ['Editor', 'Approver', 'Admin'];
    }

    function approverOrAdmin() {
      return role() in ['Approver', 'Admin'];
    }

    function admin() {
      return role() == 'Admin';
    }

    function queueItemVisible(item) {
      return admin() ||
        ('assignee_uid' in item && item.assignee_uid == request.auth.uid) ||
        (
          'required_approver_uid' in item &&
          item.required_approver_uid == request.auth.uid
        );
    }

    function queueActivityItemVisible(activity) {
      return 'item_id' in activity &&
        exists(/databases/$(database)/documents/approval_queue_items/$(activity.item_id)) &&
        queueItemVisible(
          get(/databases/$(database)/documents/approval_queue_items/$(activity.item_id)).data
        );
    }

    function queueNotificationVisible(notification) {
      return admin() ||
        (
          'recipient_uid' in notification &&
          notification.recipient_uid == request.auth.uid
        );
    }

    function active() {
      return !('deleted_at' in resource.data);
    }

    function requestSoftDeletes() {
      return 'deleted_at' in request.resource.data;
    }

    function spaceWritable(spaceId) {
      return exists(/databases/$(database)/documents/spaces/$(spaceId)) &&
        get(/databases/$(database)/documents/spaces/$(spaceId)).data.read_only != true;
    }

    function sameSpace() {
      return request.resource.data.space_id == resource.data.space_id;
    }

    function statusIsNotApproved() {
      return !('status' in request.resource.data) ||
        request.resource.data.status != 'Approved';
    }

    function statusIsNotResolved() {
      return !('status' in request.resource.data) ||
        request.resource.data.status != 'Resolved';
    }

    function canWriteApprovedStatus() {
      return statusIsNotApproved() || approverOrAdmin();
    }

    function canWriteResolvedStatus() {
      return statusIsNotResolved() || approverOrAdmin();
    }

    match /spaces/{spaceId} {
      allow read: if signedIn() && editorOrBetter();
      allow create, update: if signedIn() && admin();
      allow delete: if false;
    }

    match /sops/{sopId} {
      allow read: if signedIn() && editorOrBetter();
      allow create: if signedIn() &&
        editorOrBetter() &&
        spaceWritable(request.resource.data.space_id) &&
        canWriteApprovedStatus() &&
        !requestSoftDeletes();
      allow update: if signedIn() &&
        resource != null &&
        active() &&
        sameSpace() &&
        spaceWritable(resource.data.space_id) &&
        (
          (editorOrBetter() && canWriteApprovedStatus() && !requestSoftDeletes()) ||
          (admin() && requestSoftDeletes())
        );
      allow delete: if false;
    }

    match /templates/{templateId} {
      allow read: if signedIn() && editorOrBetter();
      allow create: if signedIn() &&
        editorOrBetter() &&
        spaceWritable(request.resource.data.space_id) &&
        canWriteApprovedStatus() &&
        !requestSoftDeletes();
      allow update: if signedIn() &&
        resource != null &&
        active() &&
        sameSpace() &&
        spaceWritable(resource.data.space_id) &&
        (
          (editorOrBetter() && canWriteApprovedStatus() && !requestSoftDeletes()) ||
          (admin() && requestSoftDeletes())
        );
      allow delete: if false;
    }

    match /placeholders/{placeholderId} {
      allow read: if signedIn() && editorOrBetter();
      allow create: if signedIn() &&
        editorOrBetter() &&
        spaceWritable(request.resource.data.space_id) &&
        canWriteResolvedStatus() &&
        !requestSoftDeletes();
      allow update: if signedIn() &&
        resource != null &&
        active() &&
        sameSpace() &&
        spaceWritable(resource.data.space_id) &&
        (
          (editorOrBetter() && canWriteResolvedStatus() && !requestSoftDeletes()) ||
          (admin() && requestSoftDeletes())
        );
      allow delete: if false;
    }

    match /tools/{toolId} {
      allow read: if signedIn() && editorOrBetter();
      allow create: if signedIn() && editorOrBetter() && !requestSoftDeletes();
      allow update: if signedIn() &&
        resource != null &&
        active() &&
        (
          (editorOrBetter() && !requestSoftDeletes()) ||
          (admin() && requestSoftDeletes())
        );
      allow delete: if false;
    }

    match /sources_meta/{sourceId} {
      allow read: if signedIn() && editorOrBetter();
      allow create, update: if signedIn() && admin();
      allow delete: if false;
    }

    match /ask_logs/{logId} {
      allow read: if signedIn() && editorOrBetter();
      allow create, update, delete: if false;
    }

    match /users/{userId} {
      allow read: if signedIn() && editorOrBetter();
      allow write: if signedIn() && admin();
      allow delete: if false;
    }

    match /change_log/{changeId} {
      allow read: if signedIn() && editorOrBetter();
      allow create: if signedIn() && editorOrBetter();
      allow update, delete: if false;
    }

    match /notification_logs/{logId} {
      allow read: if signedIn() && admin();
      allow create, update, delete: if false;
    }

    // Approval Queue v1 items and Activity are written server-side through the
    // Admin SDK boundary only. Clients may read but never write directly; the
    // Activity log is append-only.
    match /approval_queue_items/{itemId} {
      allow read: if signedIn() && editorOrBetter() && queueItemVisible(resource.data);
      allow create, update, delete: if false;
    }

    match /approval_queue_activity/{activityId} {
      allow read: if signedIn() && editorOrBetter() &&
        queueActivityItemVisible(resource.data);
      allow create, update, delete: if false;
    }

    match /approval_queue_notifications/{notificationId} {
      allow read: if signedIn() && editorOrBetter() &&
        queueNotificationVisible(resource.data);
      allow create, update, delete: if false;
    }

    match /approval_queue_email_settings/{settingId} {
      allow read: if signedIn() && admin();
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
