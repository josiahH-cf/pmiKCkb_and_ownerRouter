rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return request.auth.token.role;
    }

    function editorOrBetter() {
      return role() in ['Editor', 'Approver', 'Admin'];
    }

    function approverOrAdmin() {
      return role() in ['Approver', 'Admin'];
    }

    function admin() {
      return role() == 'Admin';
    }

    function queueItemVisible(item) {
      return admin() ||
        ('assignee_uid' in item && item.assignee_uid == request.auth.uid) ||
        (
          'required_approver_uid' in item &&
          item.required_approver_uid == request.auth.uid
        );
    }

    function queueActivityItemVisible(activity) {
      return 'item_id' in activity &&
        exists(/databases/$(database)/documents/approval_queue_items/$(activity.item_id)) &&
        queueItemVisible(
          get(/databases/$(database)/documents/approval_queue_items/$(activity.item_id)).data
        );
    }

    function queueNotificationVisible(notification) {
      return admin() ||
        (
          'recipient_uid' in notification &&
          notification.recipient_uid == request.auth.uid
        );
    }

    function active() {
      return !('deleted_at' in resource.data);
    }

    function requestSoftDeletes() {
      return 'deleted_at' in request.resource.data;
    }

    function spaceWritable(spaceId) {
      return exists(/databases/$(database)/documents/spaces/$(spaceId)) &&
        get(/databases/$(database)/documents/spaces/$(spaceId)).data.read_only != true;
    }

    function sameSpace() {
      return request.resource.data.space_id == resource.data.space_id;
    }

    function statusIsNotApproved() {
      return !('status' in request.resource.data) ||
        request.resource.data.status != 'Approved';
    }

    function statusIsNotResolved() {
      return !('status' in request.resource.data) ||
        request.resource.data.status != 'Resolved';
    }

    function canWriteApprovedStatus() {
      return statusIsNotApproved() || approverOrAdmin();
    }

    function canWriteResolvedStatus() {
      return statusIsNotResolved() || approverOrAdmin();
    }

    match /spaces/{spaceId} {
      allow read: if signedIn() && editorOrBetter();
      allow create, update: if signedIn() && admin();
      allow delete: if false;
    }

    match /sops/{sopId} {
      allow read: if signedIn() && editorOrBetter();
      allow create: if signedIn() &&
        editorOrBetter() &&
        spaceWritable(request.resource.data.space_id) &&
        canWriteApprovedStatus() &&
        !requestSoftDeletes();
      allow update: if signedIn() &&
        resource != null &&
        active() &&
        sameSpace() &&
        spaceWritable(resource.data.space_id) &&
        (
          (editorOrBetter() && canWriteApprovedStatus() && !requestSoftDeletes()) ||
          (admin() && requestSoftDeletes())
        );
      allow delete: if false;
    }

    match /templates/{templateId} {
      allow read: if signedIn() && editorOrBetter();
      allow create: if signedIn() &&
        editorOrBetter() &&
        spaceWritable(request.resource.data.space_id) &&
        canWriteApprovedStatus() &&
        !requestSoftDeletes();
      allow update: if signedIn() &&
        resource != null &&
        active() &&
        sameSpace() &&
        spaceWritable(resource.data.space_id) &&
        (
          (editorOrBetter() && canWriteApprovedStatus() && !requestSoftDeletes()) ||
          (admin() && requestSoftDeletes())
        );
      allow delete: if false;
    }

    match /placeholders/{placeholderId} {
      allow read: if signedIn() && editorOrBetter();
      allow create: if signedIn() &&
        editorOrBetter() &&
        spaceWritable(request.resource.data.space_id) &&
        canWriteResolvedStatus() &&
        !requestSoftDeletes();
      allow update: if signedIn() &&
        resource != null &&
        active() &&
        sameSpace() &&
        spaceWritable(resource.data.space_id) &&
        (
          (editorOrBetter() && canWriteResolvedStatus() && !requestSoftDeletes()) ||
          (admin() && requestSoftDeletes())
        );
      allow delete: if false;
    }

    match /tools/{toolId} {
      allow read: if signedIn() && editorOrBetter();
      allow create: if signedIn() && editorOrBetter() && !requestSoftDeletes();
      allow update: if signedIn() &&
        resource != null &&
        active() &&
        (
          (editorOrBetter() && !requestSoftDeletes()) ||
          (admin() && requestSoftDeletes())
        );
      allow delete: if false;
    }

    match /sources_meta/{sourceId} {
      allow read: if signedIn() && editorOrBetter();
      allow create, update: if signedIn() && admin();
      allow delete: if false;
    }

    // Action Registry is a server-seeded catalog (Admin SDK only). Client writes stay
    // denied so readiness and the production_allowed gate cannot be changed from the app.
    match /action_registry/{actionId} {
      allow read: if signedIn() && editorOrBetter();
      allow create, update, delete: if false;
    }

    match /ask_logs/{logId} {
      allow read: if signedIn() && editorOrBetter();
      allow create, update, delete: if false;
    }

    match /users/{userId} {
      allow read: if signedIn() && editorOrBetter();
      allow write: if signedIn() && admin();
      allow delete: if false;
    }

    match /change_log/{changeId} {
      allow read: if signedIn() && editorOrBetter();
      allow create: if signedIn() && editorOrBetter();
      allow update, delete: if false;
    }

    match /notification_logs/{logId} {
      allow read: if signedIn() && admin();
      allow create, update, delete: if false;
    }

    // Approval Queue v1 items and Activity are written server-side through the
    // Admin SDK boundary only. Clients may read but never write directly; the
    // Activity log is append-only.
    match /approval_queue_items/{itemId} {
      allow read: if signedIn() && editorOrBetter() && queueItemVisible(resource.data);
      allow create, update, delete: if false;
    }

    match /approval_queue_activity/{activityId} {
      allow read: if signedIn() && editorOrBetter() &&
        queueActivityItemVisible(resource.data);
      allow create, update, delete: if false;
    }

    match /approval_queue_notifications/{notificationId} {
      allow read: if signedIn() && editorOrBetter() &&
        queueNotificationVisible(resource.data);
      allow create, update, delete: if false;
    }

    match /approval_queue_email_settings/{settingId} {
      allow read: if signedIn() && admin();
      allow create, update, delete: if false;
    }

    // Owner transactional/notice destination (D-1 support). Single admin-editable doc; writes are
    // server-only through the manageAdmin-guarded route, so the browser can never forge the address.
    match /owner_transactional_destination/{docId} {
      allow read: if signedIn() && admin();
      allow create, update, delete: if false;
    }

    // S20 execution authority is server-only. The browser receives bounded projections through
    // authenticated workflow routes; it can never forge risk, approval, preview hash, attempt count,
    // outcome, or append-only Activity by writing Firestore directly.
    match /action_executions/{executionId} {
      allow read, write: if false;
    }

    match /action_execution_activity/{activityId} {
      allow read, write: if false;
    }

    // S25/S26 provider-orchestration state is server-only and bodyless. The browser cannot forge
    // previews, dependency receipts, one-attempt claims, reconciliation, or correction audit.
    match /external_action_executions/{executionId} {
      allow read, write: if false;
    }

    match /external_action_execution_audit/{auditId} {
      allow read, write: if false;
    }

    // Workflow-control foundation records are written server-side only. Client
    // writes stay denied so simulation-only and activation gates cannot be bypassed.
    match /process_definitions/{definitionId} {
      allow read: if signedIn() && editorOrBetter();
      allow create, update, delete: if false;
    }

    match /process_definition_versions/{versionId} {
      allow read: if signedIn() && editorOrBetter();
      allow create, update, delete: if false;
    }

    match /workflow_runs/{runId} {
      allow read: if signedIn() && editorOrBetter();
      allow create, update, delete: if false;
    }

    match /workflow_run_timeline/{timelineId} {
      allow read: if signedIn() && editorOrBetter();
      allow create, update, delete: if false;
    }

    // Lease Renewal Phase-1 resolutions and their append-only Activity are written server-side
    // through the Admin SDK boundary only. Clients may read but never write directly, so the
    // suggest-then-approve resolution loop and the no-execute write-back gate cannot be bypassed.
    match /lease_renewal_resolutions/{resolutionId} {
      allow read: if signedIn() && editorOrBetter();
      allow create, update, delete: if false;
    }

    match /lease_renewal_resolution_activity/{activityId} {
      allow read: if signedIn() && editorOrBetter();
      allow create, update, delete: if false;
    }

    // Per-lease live renewal PROGRESS (Phase A: the clickable front-to-back flow) and its append-only
    // activity. Written only through the edit-gated Admin SDK boundary; it holds the operator's forward
    // state (owner decision, tenant-offer draft id, complete) and changes NO system of record. Staff may
    // read it; no browser client may forge a stage, a decision, or a completion.
    match /lease_renewal_progress/{leaseId} {
      allow read: if signedIn() && editorOrBetter();
      allow create, update, delete: if false;
    }

    match /lease_renewal_progress_activity/{activityId} {
      allow read: if signedIn() && editorOrBetter();
      allow create, update, delete: if false;
    }

    // Persistent production Test renewal journeys and their bodyless attempt/receipt evidence are
    // written only through edit-gated Admin SDK routes. Authenticated staff may read the Test state,
    // but no browser can forge lane, status, confirmation, attempt count, or provider-contact proof.
    match /lease_renewal_test_runs/{runId} {
      allow read: if signedIn() && editorOrBetter();
      allow create, update, delete: if false;
    }

    match /lease_renewal_test_action_attempts/{attemptId} {
      allow read: if signedIn() && editorOrBetter();
      allow create, update, delete: if false;
    }

    match /lease_renewal_test_action_receipts/{receiptId} {
      allow read: if signedIn() && editorOrBetter();
      allow create, update, delete: if false;
    }

    match /lease_renewal_test_business_events/{eventId} {
      allow read: if signedIn() && editorOrBetter();
      allow create, update, delete: if false;
    }

    // Per-user renewal-decider Seen/Deferred markers (S14 B6). Written server-side through the
    // edit-gated Admin SDK boundary only. Unlike shared renewal decisions, these are personal
    // navigation markers: clients may read ONLY their own current + Activity records, including
    // Admin clients, and may never write either collection directly.
    match /renewal_decider_progress/{progressId} {
      allow read: if signedIn() && editorOrBetter() &&
        ('user_uid' in resource.data && resource.data.user_uid == request.auth.uid);
      allow create, update, delete: if false;
    }

    match /renewal_decider_progress_activity/{activityId} {
      allow read: if signedIn() && editorOrBetter() &&
        ('actor_uid' in resource.data && resource.data.actor_uid == request.auth.uid);
      allow create, update, delete: if false;
    }

    // Lease Renewal Phase-2 write-back approvals and their append-only Activity are written server-side
    // through the Admin SDK boundary only (Admin capability enforced there). Clients may read but never
    // write directly, so the admin-gated approval and the no-execute write-back gate cannot be bypassed.
    match /lease_renewal_writeback_approvals/{approvalId} {
      allow read: if signedIn() && editorOrBetter();
      allow create, update, delete: if false;
    }

    match /lease_renewal_writeback_approval_activity/{activityId} {
      allow read: if signedIn() && editorOrBetter();
      allow create, update, delete: if false;
    }

    // Renewal-notice rule engine config (S13 F1): the app's own timing rules, seeded server-side
    // through the Admin SDK boundary only. Clients may read the effective rules but never write, so
    // the timing rules cannot be changed from the app until the named Admin edit surface lands.
    match /lease_renewal_notice_rules/{configId} {
      allow read: if signedIn() && editorOrBetter();
      allow create, update, delete: if false;
    }

    // In-app role-change audit (console overhaul Slice D). Written server-side through the Admin SDK
    // boundary only; Admin-only read (the Admin page reads it server-side). Append-only.
    match /admin_role_changes/{changeId} {
      allow read: if signedIn() && admin();
      allow create, update, delete: if false;
    }

    // In-app space-scope audit (S16). Same boundary as role changes: Admin-readable and
    // server-written only; no direct client may forge, mutate, or delete an audit entry.
    match /admin_scope_changes/{changeId} {
      allow read: if signedIn() && admin();
      allow create, update, delete: if false;
    }

    // Maintenance Work Order Intake ticket queue + append-only Activity (console overhaul Slice E).
    // Written server-side through the Admin SDK boundary only (edit capability enforced there); staff
    // may read, no client writes, so the lifecycle and the gated RentVine create cannot be bypassed.
    match /maintenance_tickets/{ticketId} {
      allow read: if signedIn() && editorOrBetter();
      allow create, update, delete: if false;
    }

    match /maintenance_ticket_activity/{activityId} {
      allow read: if signedIn() && editorOrBetter();
      allow create, update, delete: if false;
    }

    // Public tokenized maintenance intake (A5). The UNVERIFIED quarantine queue + its append-only
    // Activity are written server-side ONLY, through the token-gated no-actor Admin SDK writer — never a
    // client credential. Staff may read to triage/promote; no client writes, so an unauthenticated
    // reporter can never reach the real ticket queue or a system of record. The single-use nonce, the
    // per-property rate counter, and the revocation epoch are server-only bookkeeping with NO client
    // access at all (reading them would leak the abuse-control state).
    match /maintenance_unverified_intake/{intakeId} {
      allow read: if signedIn() && editorOrBetter();
      allow create, update, delete: if false;
    }

    match /maintenance_unverified_intake_activity/{activityId} {
      allow read: if signedIn() && editorOrBetter();
      allow create, update, delete: if false;
    }

    match /maintenance_intake_nonce/{jti} {
      allow read, write: if false;
    }

    match /maintenance_intake_rate_counter/{counterId} {
      allow read, write: if false;
    }

    match /maintenance_intake_epoch/{propertyKey} {
      allow read, write: if false;
    }

    // In-app notification framework (console overhaul Slice 3b). Both collections are written
    // server-side through the Admin SDK boundary only; a signed-in editor may read ONLY their own
    // records (Admin may read any), and every client write is denied. In-app only: there is no email
    // channel and email stays hard-off.
    match /maintenance_ticket_notifications/{notificationId} {
      allow read: if signedIn() && editorOrBetter() &&
        (admin() ||
          ('recipient_uid' in resource.data && resource.data.recipient_uid == request.auth.uid));
      allow create, update, delete: if false;
    }

    match /user_notification_preferences/{userId} {
      allow read: if signedIn() && editorOrBetter() &&
        (admin() || userId == request.auth.uid);
      allow create, update, delete: if false;
    }

    // S19 Gmail operational state is server-only. The web client receives bounded projections through
    // authenticated routes and can never read/write confirmations, payload hashes, delivery audit,
    // mailbox cursors, or Pub/Sub replay state directly. These records never contain bodies or MIME.
    match /gmail_send_confirmations/{confirmationId} {
      allow read, write: if false;
    }

    match /gmail_send_audit/{auditId} {
      allow read, write: if false;
    }

    match /gmail_mailbox_state/{mailboxId} {
      allow read, write: if false;
    }

    match /gmail_push_dedupe/{messageId} {
      allow read, write: if false;
    }

    match /gmail_sync_audit/{auditId} {
      allow read, write: if false;
    }

    // Bodyless Gmail-to-workflow links and their append-only audit are also server-only. Route-level
    // authorization checks the referenced renewal/maintenance entity before returning a projection.
    match /gmail_workflow_communications/{communicationId} {
      allow read, write: if false;
    }

    match /gmail_workflow_communication_audit/{auditId} {
      allow read, write: if false;
    }

    // S24 retention cleanup and legal-hold decisions are server-only and bodyless. Even Admins use
    // the reasoned API boundary; a browser cannot forge a hold, release one, or rewrite counts.
    match /gmail_retention_audit/{auditId} {
      allow read, write: if false;
    }

    // S22 external Vendor state is server-only. Vendor routes re-check verified-email TOTP and the
    // uid -> vendor -> assigned-ticket join before returning bounded projections. OAuth state,
    // token-secret references, send confirmations, revocation work, and bodyless audit are never
    // directly readable or writable by either staff or Vendor browsers.
    match /vendors/{vendorId} {
      allow read, write: if false;
    }

    match /vendor_ticket_assignments/{assignmentId} {
      allow read, write: if false;
    }

    match /vendor_ticket_thread_links/{linkId} {
      allow read, write: if false;
    }

    match /vendor_oauth_states/{stateId} {
      allow read, write: if false;
    }

    match /vendor_mailbox_connections/{connectionId} {
      allow read, write: if false;
    }

    match /vendor_send_confirmations/{confirmationId} {
      allow read, write: if false;
    }

    match /vendor_token_revocation_queue/{jobId} {
      allow read, write: if false;
    }

    match /vendor_audit/{auditId} {
      allow read, write: if false;
    }

    // Connector connection records are server-only: they hold an opaque secret reference (never a
    // secret value) and are written only by the Admin-guarded connect/disconnect API. No browser
    // client may read or forge them.
    match /connector_connections/{connectionId} {
      allow read, write: if false;
    }

    // S21 trusted publication is entirely server-owned. Policy changes require the
    // route-level manageAdmin gate; validated versions, Active pointers, and bodyless
    // audits are one transaction that no browser client may forge or rewrite.
    match /publication_policies/{policyId} {
      allow read: if signedIn() && admin();
      allow create, update, delete: if false;
    }

    match /publication_policy_audit/{auditId} {
      allow read: if signedIn() && admin();
      allow create, update, delete: if false;
    }

    match /publication_resources/{resourceId} {
      allow read, write: if false;
    }

    match /publication_versions/{versionId} {
      allow read, write: if false;
    }

    match /publication_content_chunks/{chunkId} {
      allow read, write: if false;
    }

    match /publication_audit/{auditId} {
      allow read, write: if false;
    }

    // Add-a-Space request intake (Slice 7). Admin captures the request through the manageAdmin-guarded
    // route; the record is server-written through the Admin SDK only, so the browser can never forge a
    // request. Admin-only read. The record is intent only and provisions nothing.
    match /space_requests/{requestId} {
      allow read: if signedIn() && admin();
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
