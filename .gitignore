# Dependencies
node_modules/

# Next.js
.next/
.next-dev/
out/

# Build and coverage
coverage/
dist/
*.tsbuildinfo

# Local environment
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*

# Local diagnostic artifacts and raw review context
temp/
docs/context_and_calls/
# Client-provided source material: spreadsheets, ledgers, invoices, tool-access
# records, and any secrets they contain must stay local and never be committed.
docs/client_docs/
# Local-only secrets (API keys, tokens) kept on this machine but never committed.
secrets/

# Service-account keys, credential files, and provider state. Targeted patterns only so
# real repo JSON (package.json, firebase.json, tsconfig.json, etc.) is never ignored.
*-key.json
*-sa.json
*service-account*.json
*serviceaccount*.json
*-credentials.json
application_default_credentials.json
gha-creds-*.json
adc.json
*.pem
.terraform/
*.tfstate
*.tfstate.*
!docs/temp/
docs/temp/*
!docs/temp/README.md

# Claude Code runtime locks (harness-generated; never commit)
.claude/*.lock

# OS/editor
.DS_Store
Thumbs.db
.vscode/
.idea/
