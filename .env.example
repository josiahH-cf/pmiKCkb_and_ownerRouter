# PMI KC KB local environment template. Do not put secrets in git.

ALLOWED_HD=pmikcmetro.com
NEXT_PUBLIC_APP_NAME="PMI KC KB"

# Google Cloud / Firebase / Identity Platform
GCP_PROJECT_ID=
FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
FIRESTORE_DATABASE_ID=(default)
VERTEX_AI_LOCATION=us-central1
VERTEX_SEARCH_LOCATION=us
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FIREBASE_GOOGLE_CLIENT_ID=
FIREBASE_GOOGLE_CLIENT_SECRET=
# Firebase Admin creates and verifies this HTTP-only session cookie server-side.
AUTH_SESSION_COOKIE=__session
LOCAL_DEMO_AUTH=true

# Vertex AI Search / Gemini
# Keep live smoke and demo deploy cheap; override to Pro only after explicit approval.
GEMINI_MODEL_ANSWER=gemini-2.5-flash
GEMINI_MODEL_CLASSIFY=gemini-2.5-flash
GROUNDING_CONFIDENCE_THRESHOLD=
# Legacy env name: values can be Drive folder IDs or Cloud Storage source prefixes.
SPACE_DRIVE_FOLDER_IDS={}
SPACE_VERTEX_DATA_STORE_IDS={}
# Maintenance photo storage. Dev defaults to a free stub; production forces a Google Drive in-boundary
# upload. Set this to the in-boundary Drive folder id (a real folder id, NOT a gs:// prefix) from
# `npm run maintenance:ensure-folder`. Kept separate from SPACE_DRIVE_FOLDER_IDS (the KB-source map). The
# production cutover preflight requires it, and the deploy forwards it to Cloud Run.
MAINTENANCE_PHOTO_DRIVE_FOLDER_ID=
ASK_DEMO_MODE=true
# Optional only for an explicitly named non-production deployment running a production build.
# Ordinary production ignores fixture flags and forces live Console/Ask providers.
CONSOLE_TEST_DEPLOYMENT_NAME=

# Cloud Run demo deploy
CLOUD_RUN_SERVICE_ACCOUNT=

# Workflow-linked Gmail operational metadata only. Production linkage stays closed until a
# retention period is owner-approved and configured. Message bodies/MIME/attachments are never stored.
GMAIL_WORKFLOW_LINK_TTL_DAYS=

# Legacy approval-email switch. Governance keeps this false; approval attention is in-app only.
KB_APPROVAL_LABEL="KB Approval"
KB_APPROVAL_NOTIFICATIONS_ENABLED=false
KB_APPROVAL_SENDER=
KB_APPROVAL_RECIPIENTS=
APP_BASE_URL=http://localhost:3000

# Lease-renewal Google Sheet (the team's "Tenant Move In/Out/Renewal Checklist" control sheet).
# Read-only. The sheet id is a client identifier kept local (never committed). On a managed Workspace
# domain the user OAuth flow is blocked from the Sheets scope, so the reader impersonates a read-only
# service account (the sheet is shared with it; the human holds Token Creator on it). Set
# SHEETS_IMPERSONATE_SA to that SA email; leave it unset to use plain ADC where the Sheets scope is
# permitted. See docs/products/rentvine-connection-setup.md.
RENEWAL_SHEET_ID=
SHEETS_IMPERSONATE_SA=
# Optional: when the managed domain blocks the external SA from opening the file, set this to a domain
# user (e.g. an editor on the sheet) so the SA reads via domain-wide delegation AS that user. Requires
# the SA's client id be authorized for the Sheets scope in Admin console → Domain-wide delegation.
SHEETS_DWD_SUBJECT=

# S19 per-user Gmail transport. Non-secret identifiers only. The exact DWD scopes and
# authenticated Pub/Sub/watch were owner-approved and transport-proven 2026-07-13. Product use is
# workflow-linked; generic send is disabled and any reply remains exact-confirmed.
GMAIL_DWD_SA=
GMAIL_PUBSUB_TOPIC=
GMAIL_PUBSUB_AUDIENCE=
GMAIL_PUBSUB_PUSH_SERVICE_ACCOUNT=

# RentVine (property-management system of record). RentVine's API is the owner's own account,
# not a Google service, so reading from it does not spend against the GCP budget. Load these from
# env/Secret Manager; never commit them. The base URL plus the auth/endpoint details come from
# RentVine's API docs. See docs/products/rentvine-connection-setup.md.
# Dev↔prod parity: the deploy forwards the (non-secret) base URL as an env var and delivers the key
# + secret via Secret Manager (--set-secrets), wired automatically when the base URL is set. The
# Secret Manager secret id defaults to the env var name; override with RENTVINE_API_KEY_SECRET_ID /
# RENTVINE_API_SECRET_SECRET_ID (+ *_SECRET_VERSION, default latest). The cutover preflight requires
# the base URL (pmikcmetro tenant), RENEWAL_SHEET_ID, and the SHEETS_* DWD identity above.
RENTVINE_API_BASE_URL=
RENTVINE_API_KEY=
RENTVINE_API_SECRET=

# Dotloop OAuth app (lease documents + e-signature). Names locked by S13 D3; the team's existing
# credentials land here (or in Secret Manager) when Dotloop work starts. Presence only powers the
# Connection Center status today — no Dotloop client code runs yet.
DOTLOOP_OAUTH_CLIENT_ID=
DOTLOOP_OAUTH_CLIENT_SECRET=

# LeadSimple REST API (renewal pipeline stages + follow-up tasks). Same seam rule as Dotloop.
LEADSIMPLE_API_KEY=

# Autonomous loop cost/away-mode overlay (optional; safe defaults already apply when unset).
# Budget ceiling for unattended cloud work. Canonical policy: docs/budget-and-cost-policy.md.
# The reversible vacation overlay (on/off) lives in docs/away-mode.md, not here.
AUTONOMOUS_BUDGET_CAP_USD=10
